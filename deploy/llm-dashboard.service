[Unit]
Description=LLM Dashboard
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/llm-stack/dashboard/server.py
WorkingDirectory=/opt/llm-stack/dashboard
Environment=PATH=/opt/rocm/bin:/usr/local/bin:/usr/bin:/bin
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
